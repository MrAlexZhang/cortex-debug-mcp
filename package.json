{
  "name": "embedded-ai-debug",
  "displayName": "Embedded AI Debug",
  "description": "AI-powered debug bridge for embedded systems — exposes a local MCP server so Claude Code and other AI tools can read live debug state (variables, registers, memory, call stack) from Cortex-Debug sessions.",
  "version": "0.0.7",
  "publisher": "paulopalaoro",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paulopalaoro/cortex-mcp-bridge"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "cortex-debug",
    "mcp",
    "claude",
    "stm32",
    "embedded",
    "arm",
    "debug"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onDebugType:cortex-debug",
    "onDebugType:platformio-debug"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "embedded-ai-debug.startServer",
        "title": "AI Debug: Start Bridge Server"
      },
      {
        "command": "embedded-ai-debug.stopServer",
        "title": "AI Debug: Stop Bridge Server"
      },
      {
        "command": "embedded-ai-debug.copyMcpConfig",
        "title": "AI Debug: Copy .mcp.json config to clipboard"
      },
      {
        "command": "embedded-ai-debug.showStatus",
        "title": "AI Debug: Show Server Status"
      },
      {
        "command": "embedded-ai-debug.resetPermission",
        "title": "AI Debug: Reset Auto-Start Permission"
      },
      {
        "command": "embedded-ai-debug.openPeripheralTester",
        "title": "AI Debug: Open Peripheral Tester",
        "icon": "$(circuit-board)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "embedded-ai-debug.openPeripheralTester",
          "group": "navigation",
          "when": "embeddedAiDebugRunning"
        }
      ]
    },
    "configuration": {
      "title": "Embedded AI Debug",
      "properties": {
        "embeddedAiDebug.port": {
          "type": "number",
          "default": 7580,
          "description": "Local TCP port for the MCP HTTP/SSE server. If the port is busy, the extension tries the next available port automatically."
        },
        "embeddedAiDebug.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the MCP server when a Cortex-Debug or PlatformIO debug session starts."
        },
        "embeddedAiDebug.logLevel": {
          "type": "string",
          "enum": [
            "off",
            "info",
            "debug"
          ],
          "default": "info",
          "description": "Log verbosity in the Output panel."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p . --noEmit",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies",
    "install-ext": "code --install-extension cortex-mcp-bridge-0.1.0.vsix"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "sharp": "^0.34.5",
    "typescript": "^5.4.0"
  }
}
